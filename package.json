{
    "name": "foxifill-extension",
    "version": "1.0.3",
    "description": "AI-powered local-first browser extension for form capture and autofill workflows",
    "type": "module",
    "license": "MIT",
    "homepage": "https://foxifill.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/FoxiFill/foxifill-extension.git"
    },
    "bugs": {
        "url": "https://github.com/FoxiFill/foxifill-extension/issues"
    },
    "keywords": [
        "browser-extension",
        "chrome-extension",
        "manifest-v3",
        "typescript",
        "react",
        "ai-form-filler",
        "form-filling"
    ],
    "scripts": {
        "dev": "vite",
        "build": "npm run create-icons && tsc && vite build && npm run build-content && npm run build-background && npm run copy-manifest && npm run copy-icons && npm run fix-paths",
        "build:prod": "npm run create-icons && tsc && vite build --mode production && npm run build-content-prod && npm run build-background-prod && npm run copy-manifest && npm run copy-icons && npm run fix-paths",
        "build-content": "esbuild src/content/content.ts --bundle --format=iife --outfile=dist/content/content.js --platform=browser --target=es2020",
        "build-content-prod": "esbuild src/content/content.ts --bundle --format=iife --outfile=dist/content/content.js --platform=browser --target=es2020 --minify",
        "build-background": "esbuild src/background/sw.ts --bundle --format=iife --outfile=dist/background/sw.js --platform=browser --target=es2020",
        "build-background-prod": "esbuild src/background/sw.ts --bundle --format=iife --outfile=dist/background/sw.js --platform=browser --target=es2020 --minify",
        "create-icons": "python3 scripts/create-icons.py",
        "copy-manifest": "cp src/manifest.json dist/",
        "copy-icons": "cp -r public/* dist/ && mkdir -p dist/content && cp dist/content/content.js dist/content.js",
        "fix-paths": "node scripts/fix-paths.mjs",
        "build:quick": "./scripts/build-prod.sh",
        "preview": "vite preview",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "css-selector-generator": "^3.6.7",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "string-similarity-js": "^2.1.4",
        "zod": "^3.22.4",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@types/chrome": "^0.0.251",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@typescript-eslint/eslint-plugin": "^8.62.0",
        "@typescript-eslint/parser": "^8.62.0",
        "@vitejs/plugin-react": "^6.0.3",
        "autoprefixer": "^10.4.16",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "postcss": "^8.5.15",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.2.2",
        "vite": "^8.1.0"
    }
}
