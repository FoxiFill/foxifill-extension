{
    "manifest_version": 3,
    "name": "FoxiFill",
    "version": "1.0.3",
    "description": "Intelligent form filling assistant that captures web forms and generates AI-powered suggestions for automatic completion",
    "permissions": [
        "activeTab",
        "storage",
        "clipboardWrite",
        "scripting",
        "tabs",
        "contextMenus"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/sw.js"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "FoxiFill - AI Form Assistant",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "externally_connectable": {
        "matches": [
            "*://localhost/*",
            "*://foxifill.com/*"
        ]
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}
